<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ILPEA — <%= typeof title !== 'undefined' ? title : 'Sistema de Rutas' %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

<header class="header-mobile">
  <button class="menu-toggle" onclick="toggleSidebar()">
    <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>
  <div class="mobile-brand">ILPEA</div>
  <div style="width: 24px;"></div> <!-- Spacer -->
</header>

<div class="app-wrapper">
  <!-- SIDEBAR -->
  <aside id="appSidebar" class="sidebar">
    <div class="sidebar-logo">
      <div class="brand">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:8px; color:var(--primary)">
          <rect x="2" y="6" width="20" height="12" rx="2" />
          <path d="M6 18h4" />
          <path d="M14 18h4" />
          <path d="M16 6V4a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v2" />
          <path d="M2 10h20" />
          <circle cx="7" cy="18" r="2" />
          <circle cx="17" cy="18" r="2" />
        </svg>
        ILPEA
      </div>
      <div class="sub">Sistema de Optimización</div>
    </div>

    <% if (user) { %>
    <div class="sidebar-role">
      <div class="role-label">Rol</div>
      <div class="role-name"><%= user.role %></div>
      <div class="user-email"><%= user.email %></div>
    </div>

    <nav>
      <!-- EMPLOYEE section — visible ONLY to employees -->
      <% if (user.role === 'EMPLOYEE') { %>
      <div class="nav-section">Mi Cuenta</div>
      <a href="/empleado/mi-turno" class="nav-link <%= currentPath === '/empleado/mi-turno' ? 'active' : '' %>">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Mi Turno
      </a>
      <% } %>

      <!-- MANAGER+ -->
      <% if (['MANAGER','ADMIN'].includes(user.role)) { %>
      <div class="nav-section">Operaciones</div>
      <a href="/manager/servicios" class="nav-link <%= currentPath.startsWith('/manager/servicios') ? 'active' : '' %>">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Servicios
      </a>
      <a href="/manager/asignaciones" class="nav-link <%= currentPath.startsWith('/manager/asignaciones') ? 'active' : '' %>">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        Asignaciones
      </a>
      <a href="/manager/usuarios" class="nav-link <%= currentPath.startsWith('/manager/usuarios') ? 'active' : '' %>">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Usuarios
      </a>
      <% } %>

      <!-- ADMIN -->
      <% if (user.role === 'ADMIN') { %>
      <div class="nav-section">Administración</div>
      <a href="/admin/dashboard" class="nav-link <%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        Dashboard
      </a>
      <a href="/admin/rutas" class="nav-link <%= currentPath.startsWith('/admin/rutas') ? 'active' : '' %>">
        <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
        </svg>
        Rutas
      </a>
      <% } %>
    </nav>
    <% } %>

    <div class="sidebar-footer">
      <a href="/logout" class="logout-btn">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        Cerrar Sesión
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="main-content">

<script>
  function toggleSidebar() {
    const sidebar = document.getElementById('appSidebar');
    const overlay = document.getElementById('sidebarOverlay');
    sidebar.classList.toggle('open');
    overlay.classList.toggle('visible');
    
    // Opcional: Bloquear scroll del body cuando el menú está abierto
    if (sidebar.classList.contains('open')) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  }
</script>
