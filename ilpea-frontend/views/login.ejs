<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ILPEA — Acceso</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<div class="login-page">
  <div class="login-bg-lines"></div>
  <div class="login-card">
    <div class="login-brand">ILPEA</div>
    <div class="login-subtitle">Optimización de Rutas y Aforos</div>

    <% if (error) { %>
      <div class="login-error">⚠ <%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label class="form-label">Correo electrónico</label>
        <input type="email" name="email" class="form-control" placeholder="usuario@empresa.com" required autofocus>
      </div>
      <div class="form-group">
        <label class="form-label">Contraseña</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary">Ingresar</button>
    </form>

    <p style="margin-top:24px; font-size:12px; color:var(--text2); text-align:center;">
      LinceHackatec 2026 · Instituto Tecnológico de Celaya
    </p>
  </div>
</div>
</body>
</html>
